---
import Layout from '../layouts/Layout.astro';

const runtime = Astro.locals.runtime;
let posts = [];

try {
  const { results } = await runtime.env.DB.prepare(
    "SELECT id, title, slug, created_at FROM posts ORDER BY id DESC"
  ).all();
  posts = results;
} catch (e) {
  console.error("Database belum siap atau kosong.");
}
---

<Layout title="SkyBlog - Blog Pribadi">
  <header style="margin: 3rem 0 text-align: center;">
    <h1 style="font-size: 2.5rem; color: var(--accent);">Selamat Datang di SkyBlog</h1>
    <p style="color: var(--text-muted);">Membahas info Agen BRILink dan tutorial bermanfaat lainnya.</p>
  </header>

  <div class="feed" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
    {posts.length === 0 ? (
      <p style="text-align: center; color: var(--text-muted);">Belum ada postingan artikel.</p>
    ) : (
      posts.map((post: any) => (
        <article style="background: var(--bg-card); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border);">
          <small style="color: var(--text-muted); font-size: 0.85rem;">
            {new Date(post.created_at).toLocaleDateString('id-ID', {dateStyle: 'long'})}
          </small>
          <h2 style="margin: 0.5rem 0;">
            <a href={`/blog/${post.slug}`} style="color: var(--text-primary); text-decoration: none; font-size: 1.4rem;">
              {post.title}
            </a>
          </h2>
          <a href={`/blog/${post.slug}`} style="color: var(--accent); text-decoration: none; font-weight: bold; font-size: 0.95rem;">
            Baca Selengkapnya →
          </a>
        </article>
      ))
    )}
  </div>
</Layout>
