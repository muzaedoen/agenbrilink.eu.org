---
import Layout from '../../layouts/Layout.astro';
import AdBanner from '../../components/AdBanner.astro';
import { marked } from 'marked';

const { slug } = Astro.params;
const runtime = Astro.locals.runtime;
let post: any = null;

try {
  const { results } = await runtime.env.DB.prepare(
    "SELECT * FROM posts WHERE slug = ?"
  ).bind(slug).all();
  post = results[0];
} catch (e) {
  console.error(e);
}

if (!post) {
  return Astro.redirect('/404');
}

// ---- FITUR BARU: HITUNG OTOMATIS ESTIMASI WAKTU BACA ----
const postContent = post.content || "";
const wordsPerMinute = 200; // Kecepatan rata-rata membaca manusia
const wordCount = postContent.trim().split(/\s+/).length;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

// Render Markdown (.md) ke kode HTML murni
const htmlContent = await marked.parse(post.content);
---

<Layout title={`${post.title} - SkyBlog`}>
  <!-- FITUR BARU: GARIS INDIKATOR MEMBACA MEWAH (MELAYANG DI ATAS) -->
  <div id="reading-progress-bar"></div>

  <article class="post-wrapper">
    <header>
      <h1 class="post-title">{post.title}</h1>
      <div class="post-meta">
        <span>📅 Diterbitkan: {new Date(post.created_at).toLocaleDateString('id-ID', { dateStyle: 'long' })}</span>
        <span class="reading-time">⏱️ {readingTime} Menit Membaca</span>
      </div>
    </header>

    <AdBanner scriptCode={post.ad_script} />

    <hr class="divider" />

    <div class="markdown-body" set:html={htmlContent} />
  </article>
</Layout>

<!-- SCRIPT UNTUK JALANKAN PROGRESS BAR SAAT LAYAR DI-SCROLL -->
<script>
  window.addEventListener('scroll', () => {
    const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    
    const progressBar = document.getElementById('reading-progress-bar');
    if (progressBar) {
      progressBar.style.width = scrolled + '%';
    }
  });
</script>

<style is:global>
  /* STYLING PROGRESS BAR MELAYANG */
  #reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 4px;
    background: linear-gradient(to right, #38bdf8, #0284c7); /* Gradasi Biru Neon Mewah */
    width: 0%;
    z-index: 9999;
    transition: width 0.1s ease-out;
  }

  .post-wrapper { margin-top: 2rem; padding-bottom: 5rem; }
  .post-title { font-size: 2.2rem; color: var(--accent); line-height: 1.2; }
  
  /* MENYESUAIKAN META AGAR ADA JARAK ANTARA TANGGAL DAN WAKTU BACA */
  .post-meta { 
    color: var(--text-muted); 
    font-size: 0.9rem; 
    margin-top: 0.75rem; 
    display: flex;
    flex-wrap: wrap;
    gap: 15px; 
    align-items: center;
  }
  .post-meta .reading-time {
    background: rgba(56, 189, 248, 0.1); /* Background tipis estetik */
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 500;
  }

  .divider { border: 0; border-top: 1px solid var(--border); margin: 2rem 0; }
  
  /* Styling otomatis agar konten file .md Anda rapi di HP */
  .markdown-body p { margin-bottom: 1.25rem; line-height: 1.75; font-size: 1.05rem; }
  .markdown-body h2 { margin: 2rem 0 1rem 0; font-size: 1.6rem; color: var(--accent); }
  .markdown-body h3 { margin: 1.5rem 0 0.5rem 0; font-size: 1.25rem; }
  .markdown-body ul, .markdown-body ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .markdown-body li { margin-bottom: 0.5rem; }
  .markdown-body img { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; }
  .markdown-body strong { color: var(--accent); }
</style>
