---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body>
		<nav class="navbar">
			<div class="container nav-container">
				<a href="/" class="brand">SkyBlog</a>
				<div class="nav-links">
					<a href="/">Home</a>
					<a href="/login" class="admin-btn">Admin</a>
				</div>
			</div>
		</nav>
		<main class="container">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg-primary: #f0f9ff; /* Biru langit sangat muda */
		--bg-card: #ffffff;
		--text-primary: #0f172a;
		--text-muted: #64748b;
		--accent: #0284c7; /* Biru langit pekat */
		--border: #e2e8f0;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg-primary: #0f172a; /* Slate gelap */
			--bg-card: #1e293b;
			--text-primary: #f8fafc;
			--text-muted: #94a3b8;
			--accent: #38bdf8; /* Biru langit neon */
			--border: #334155;
		}
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		background-color: var(--bg-primary);
		color: var(--text-primary);
		font-family: system-ui, -apple-system, sans-serif;
		line-height: 1.6;
	}

	.container {
		width: 100%;
		max-width: 700px; /* Lebar ideal untuk membaca di mobile & desktop */
		margin: 0 auto;
		padding: 0 1.25rem;
	}

	.navbar {
		background-color: var(--bg-card);
		border-bottom: 1px solid var(--border);
		padding: 1rem 0;
		sticky: top;
	}

	.nav-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.brand {
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--accent);
		text-decoration: none;
	}

	.nav-links a {
		color: var(--text-primary);
		text-decoration: none;
		margin-left: 1rem;
		font-size: 0.95rem;
	}

	.nav-links .admin-btn {
		background-color: var(--accent);
		color: #fff;
		padding: 0.3rem 0.8rem;
		border-radius: 5px;
	}
  
	@media (prefers-color-scheme: dark) {
		.nav-links .admin-btn { color: #000; font-weight: bold; }
	}

<footer>
  <p>&copy; 2026 Agen Brilink</p>
</footer>

</style>
